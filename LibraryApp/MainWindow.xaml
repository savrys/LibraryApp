<Window x:Class="LibraryApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление библиотекой" Height="600" Width="900"
        Loaded="Window_Loaded">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Кнопки управления сущностями -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Авторы" Width="100" Margin="5" Click="AuthorsButton_Click"/>
            <Button Content="Жанры" Width="100" Margin="5" Click="GenresButton_Click"/>
        </StackPanel>

        <!-- Панель фильтрации и поиска -->
        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0" Content="Поиск по названию:" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="SearchTextBox" Margin="5" Height="25"/>

                <Label Grid.Column="2" Content="Жанр:" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <ComboBox Grid.Column="3" x:Name="GenreFilterComboBox" Margin="5" Height="25" DisplayMemberPath="Name" SelectedValuePath="Id"/>

                <Button Grid.Column="4" Content="Применить" Width="80" Margin="5" Click="ApplyFilterButton_Click"/>
            </Grid>
        </Border>

        <!-- DataGrid для книг -->
        <DataGrid Grid.Row="2" x:Name="BooksDataGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                  SelectionMode="Single" SelectionUnit="FullRow" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="200"/>
                <DataGridTextColumn Header="Авторы" Binding="{Binding AuthorsDisplay}" Width="200"/>
                <!-- ИСПРАВЛЕНО: используем GenresDisplay вместо Genre.Name -->
                <DataGridTextColumn Header="Жанры" Binding="{Binding GenresDisplay}" Width="150"/>
                <DataGridTextColumn Header="Год" Binding="{Binding PublishYear}" Width="70"/>
                <DataGridTextColumn Header="ISBN" Binding="{Binding ISBN}" Width="120"/>
                <DataGridTextColumn Header="В наличии" Binding="{Binding QuantityInStock}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Нижняя панель с количеством книг и кнопками -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" x:Name="TotalBooksTextBlock" Text="Всего книг: 0" VerticalAlignment="Center" Margin="5"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Добавить" Width="80" Margin="5" Click="AddBookButton_Click"/>
                <Button Content="Редактировать" Width="80" Margin="5" Click="EditBookButton_Click"/>
                <Button Content="Удалить" Width="80" Margin="5" Click="DeleteBookButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>